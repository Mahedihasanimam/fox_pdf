{
  "expo": {
    "name": "FoxPDF Tools",
    "slug": "foxpdf-tools",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF6B2B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.foxpdf.tools"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FF6B2B"
      },
      "package": "com.foxpdf.tools",
      "permissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES"
      ]
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "FoxPDF needs access to your photos to convert images to PDF.",
          "cameraPermission": "FoxPDF needs camera access to scan documents."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "FoxPDF needs access to save files.",
          "savePhotosPermission": "FoxPDF needs permission to save your PDFs."
        }
      ],
      "expo-router"
    ]
  }
}
